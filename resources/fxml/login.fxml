<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/25" 
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.connect.ui.LoginScreenController"
      alignment="CENTER" 
      spacing="30" 
      prefWidth="400" 
      prefHeight="600"
      styleClass="bg-white"
      stylesheets="@../css/connect-theme.css">
   
   <padding><Insets top="60" right="40" bottom="40" left="40"/></padding>
   
   <!-- Header Section -->
   <VBox alignment="CENTER" spacing="15">
      <Label text="Connect" styleClass="heading-1" />
      <Label text="Sign in" style="-fx-text-fill: #0678FC; -fx-font-size: 24px; -fx-font-weight: 600;" />
   </VBox>
   
   <!-- Form Section -->
   <VBox alignment="CENTER_LEFT" spacing="25" prefWidth="320">
      
      <!-- Email Field -->
      <VBox spacing="8">
         <Label text="Email" style="-fx-font-weight: 600; -fx-text-fill: #122438; -fx-font-size: 14px;" />
         <TextField fx:id="emailField" promptText="abc@email.com" styleClass="text-field" />
      </VBox>
      
      <!-- Password Field -->
      <VBox spacing="8">
         <Label text="Password" style="-fx-font-weight: 600; -fx-text-fill: #122438; -fx-font-size: 14px;" />
         <PasswordField fx:id="passwordField" promptText="Your password" styleClass="password-field" />
      </VBox>
      
      <!-- Remember Me -->
      <HBox alignment="CENTER_LEFT" spacing="85">
         <CheckBox fx:id="rememberMeCheckBox" text="Remember Me" 
                   style="-fx-text-fill: #122438; -fx-font-size: 13px;" />
      </HBox>
      
      <!-- Sign In Button -->
      <Button fx:id="signInButton" text="SIGN IN →" 
             styleClass="btn-primary" 
             prefWidth="320" prefHeight="50"
             onAction="#handleSignIn" />
      
      <!-- Sign Up Link -->
      <HBox alignment="CENTER" spacing="5">
         <Label text="Don't have an account?" style="-fx-text-fill: #666666; -fx-font-size: 14px;" />
         <Hyperlink fx:id="signUpLink" text="Sign up" 
                   style="-fx-text-fill: #0678FC; -fx-font-size: 14px; -fx-border-color: transparent; -fx-font-weight: 600; -fx-underline: false;" 
                   onAction="#handleNavigateToSignUp" />
      </HBox>
   </VBox>
</VBox>